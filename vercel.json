{
  "builds": [
    { "src": "public/**", "use": "@vercel/static" },
    { "src": "server.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "server.js" },
    { "src": "/admin", "dest": "/public/admin.html" },
    { "src": "/search", "dest": "/public/search.html" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ]
}
